# Anthropic API key (required untuk meal plan + workout generation).
# Dapetin di https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Default model. Pilih per cost/quality:
#   claude-haiku-4-5    cepet, murah, cukup buat compose meal plan
#   claude-sonnet-4-5   balanced (default)
#   claude-opus-4-5     paling akurat, lebih lambat, lebih mahal
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database path (relative ke project root)
DB_PATH=./data/sehatin.db

# Scraper config
OFF_USER_AGENT=Sehatin/0.1 (research; sehatin.masbash.id; contact@masbash.id)
OFF_RATE_LIMIT_MS=1000
